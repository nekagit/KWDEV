# Copy to .env.local and set values. Never commit .env or .env.local.

# ---- Sensitive (keep in .env / .env.local only, never commit) ----
# GitHub Personal Access Token for GitHub Connection page. When set, app uses this (server-side) instead of PAT entered in UI.
# Create at https://github.com/settings/tokens with repo scope.
# GITHUB_PAT=ghp_...

# ---- Default server (no hardcoded hosts in app) ----
# SSH host for auto-connect (Dashboard, AI Bots) and quick-connect. Must match a Host in ~/.ssh/config.
# If unset, quick-connect card and auto-connect are hidden.
# NEXT_PUBLIC_DEFAULT_SSH_HOST=your-server-alias

# ---- Analyze (Ideas, Design, etc.) ----
# Full path to the agent CLI. Find with: which agent
# AGENT_CLI_PATH=/path/to/agent

# ---- Optional ----
# Folder for Local repos (Projects page)
# FEBRUARY_DIR=/path/to/your/February

# Allow API file access (list/read/write) for project repos outside the app directory.
# Semicolon-separated absolute path prefixes (e.g. /Users/you/Documents/KW).
ALLOWED_REPO_PREFIXES=/Users/nenadkalicanin/Documents/March;/Users/nenadkalicanin/Documents/KW/Products/;
