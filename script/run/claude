#!/usr/bin/env bash
# Wrapper so "claude" in Cursor terminal runs from home (subscription works).
# Real claude is run from ~ with this project added via --add-dir.
set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
# Remove this script's dir from PATH so "claude" resolves to the real binary
export PATH="$(printf '%s\n' "$PATH" | tr ':' '\n' | grep -vFx "$SCRIPT_DIR" | paste -sd: -)"
REAL_CLAUDE="$(command -v claude)"
cd ~ && exec "$REAL_CLAUDE" --add-dir "$PROJECT_ROOT" "$@"
